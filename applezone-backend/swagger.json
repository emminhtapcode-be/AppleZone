{
  "openapi": "3.0.0",
  "info": {
    "title": "AppleZone API",
    "version": "1.0.0",
    "description": "Express.js + SQL Server backend for AppleZone"
  },
  "servers": [
    {
      "url": "http://localhost:8000/api/v1",
      "description": "Local server"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Đăng ký tài khoản mới",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["full_name", "email", "password"],
                "properties": {
                  "full_name": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "phone": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Tạo tài khoản thành công" },
          "400": { "description": "Lỗi dữ liệu đầu vào hoặc email đã tồn tại" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Đăng nhập nhận Token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Đăng nhập thành công" },
          "401": { "description": "Sai tài khoản hoặc mật khẩu" }
        }
      }
    },
    "/products": {
      "get": {
        "tags": ["Products"],
        "summary": "Lấy danh sách sản phẩm",
        "parameters": [
          { "name": "category_id", "in": "query", "required": false, "schema": { "type": "integer" } },
          { "name": "search", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "skip", "in": "query", "required": false, "schema": { "type": "integer", "default": 0 } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "Thành công" }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Chi tiết sản phẩm",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Thành công" },
          "404": { "description": "Không tìm thấy sản phẩm" }
        }
      }
    },
    "/cart": {
      "get": {
        "tags": ["Cart"],
        "summary": "Xem giỏ hàng",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Thành công" }
        }
      }
    },
    "/cart/items": {
      "post": {
        "tags": ["Cart"],
        "summary": "Thêm sản phẩm vào giỏ hàng",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["variant_id", "quantity"],
                "properties": {
                  "variant_id": { "type": "integer" },
                  "quantity": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Thêm thành công" }
        }
      }
    },
    "/cart/items/{id}": {
      "delete": {
        "tags": ["Cart"],
        "summary": "Xóa sản phẩm khỏi giỏ hàng",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Xóa thành công" },
          "404": { "description": "Không tìm thấy item" }
        }
      }
    },
    "/orders": {
      "post": {
        "tags": ["Orders"],
        "summary": "Tạo đơn hàng mới",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["shipping_address_id", "items"],
                "properties": {
                  "shipping_address_id": { "type": "integer" },
                  "coupon_code": { "type": "string" },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["variant_id", "quantity"],
                      "properties": {
                        "variant_id": { "type": "integer" },
                        "quantity": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Tạo thành công" },
          "400": { "description": "Lỗi dữ liệu hoặc hết hàng" }
        }
      },
      "get": {
        "tags": ["Orders"],
        "summary": "Danh sách đơn hàng của tôi",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Thành công" }
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Chi tiết đơn hàng",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Thành công" },
          "404": { "description": "Không tìm thấy đơn hàng" }
        }
      }
    },
    "/payments/{orderId}": {
      "post": {
        "tags": ["Payments"],
        "summary": "Thanh toán đơn hàng",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "orderId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["method"],
                "properties": {
                  "method": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Thanh toán thành công" }
        }
      }
    },
    "/admin/orders": {
      "get": {
        "tags": ["Admin"],
        "summary": "Xem tất cả đơn hàng (Admin/Staff)",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Thành công" }
        }
      }
    },
    "/admin/orders/{id}/status": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Cập nhật trạng thái đơn hàng (Admin/Staff)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "type": "string", "example": "Shipped" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Thành công" }
        }
      }
    }
  }
}
